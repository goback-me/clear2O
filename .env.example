# --- Google Drive (service account) ---
# Email of the service account created in Google Cloud Console
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Private key from the service account's downloaded JSON credentials.
# Keep the surrounding quotes and the literal \n sequences — Vercel stores
# multi-line values as a single line and the app converts \n back to real
# newlines at runtime.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ID of the Google Drive folder to upload images into (the long string in
# the folder's URL: https://drive.google.com/drive/folders/<THIS_PART>).
# This folder must live inside a Shared Drive — see SETUP.md.
GOOGLE_DRIVE_FOLDER_ID=

# --- Webhook ---
# Any endpoint that accepts a JSON POST (Zapier, Make, n8n, your own API, etc.)
WEBHOOK_URL=
